{
  "name": "Python 3 + Node.js",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py",
        "frontend/src/App.tsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; pip3 install --user streamlit; cd frontend && npm install; echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "streamlit": "streamlit run app.py --server.enableCORS false --server.enableXsrfProtection false",
    "frontend": "cd frontend && npm run dev"
  },
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openPreview"
    },
    "5173": {
      "label": "React Frontend",
      "onAutoForward": "notify"
    }
  },
  "forwardPorts": [
    8501,
    5173
  ]
}